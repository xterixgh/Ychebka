<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="750"
             x:Class="YchebnayaPractika.Pages.CreateOrderControl">
    <Grid Margin="20">
        <Border Classes="form-card" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Top" MaxWidth="640">
            <ScrollViewer MaxHeight="680">
                <StackPanel Spacing="8">
                    <TextBlock Name="TitleTextBlock"
                               Text="Оформление заказа"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrandBlueBrush}"/>

                    <TextBlock Name="OrderNumberLabel" Text="Номер заказа" IsVisible="False"/>
                    <TextBlock Name="OrderNumberTextBlock" FontWeight="Bold" IsVisible="False"/>

                    <TextBlock Name="OrderDateLabel" Text="Дата заказа" IsVisible="False"/>
                    <TextBlock Name="OrderDateTextBlock" IsVisible="False"/>

                    <TextBlock Name="OrderCostLabel" Text="Стоимость заказа" IsVisible="False"/>
                    <TextBlock Name="OrderCostTextBlock" IsVisible="False"/>

                    <TextBlock Name="PlannedDateLabel" Text="Плановый срок" IsVisible="False"/>
                    <TextBlock Name="PlannedDateTextBlock" IsVisible="False"/>

                    <TextBlock Text="Наименование заказа"/>
                    <TextBox Name="OrderNameTextBox"/>

                    <TextBlock Name="CustomerLabel" Text="Заказчик"/>
                    <ComboBox Name="CustomerComboBox"/>

                    <CheckBox Name="NewCustomerCheckBox"
                              Content="Создать нового заказчика"
                              IsVisible="False"
                              Checked="NewCustomerChecked"
                              Unchecked="NewCustomerUnchecked"/>

                    <StackPanel Name="NewCustomerPanel" IsVisible="False" Spacing="6">
                        <TextBlock Text="ФИО нового заказчика"/>
                        <TextBox Name="NewCustomerFullNameTextBox"/>
                        <TextBlock Text="Логин"/>
                        <TextBox Name="NewCustomerLoginTextBox"/>
                        <TextBlock Text="Пароль"/>
                        <TextBox Name="NewCustomerPasswordTextBox"/>
                    </StackPanel>

                    <TextBlock Text="Изделие"/>
                    <ComboBox Name="ProductComboBox"/>

                    <TextBlock Text="Количество"/>
                    <TextBox Name="QuantityTextBox" Text="1"/>

                    <TextBlock Text="Описание изделия"/>
                    <TextBox Name="DescriptionTextBox" AcceptsReturn="True" Height="70" TextWrapping="Wrap"/>

                    <TextBlock Text="Размеры готового изделия" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBlock Text="Название замера"/>
                    <TextBox Name="SizeNameTextBox"/>
                    <TextBlock Text="Значение"/>
                    <TextBox Name="SizeValueTextBox"/>
                    <TextBlock Text="Единица"/>
                    <TextBox Name="SizeUnitTextBox"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Добавить размер" MinWidth="140" Click="AddSizeClick"/>
                        <Button Content="Удалить размер" MinWidth="140" Click="DeleteSizeClick"/>
                    </StackPanel>
                    <ListBox Name="SizesListBox" MinHeight="80" MaxHeight="120"/>

                    <TextBlock Text="Чертежи и схемы заказа" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Добавить файл" MinWidth="140" Click="AddDrawingClick"/>
                        <Button Content="Удалить файл" MinWidth="140" Click="DeleteDrawingClick"/>
                    </StackPanel>
                    <ListBox Name="DrawingsListBox" MinHeight="80" MaxHeight="120"/>

                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                        <Button Name="SaveButton" Content="Сохранить" Width="120" Click="SaveClick"/>
                        <Button Content="Назад" Width="120" Click="BackClick"/>
                    </StackPanel>

                    <TextBlock Name="MessageTextBlock" Foreground="{DynamicResource BrandRedBrush}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
