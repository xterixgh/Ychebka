<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
             x:Class="YchebnayaPractika.Pages.ComponentsControl">
    <Grid Margin="20" ColumnDefinitions="2*,1*" RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.ColumnSpan="2"
                   Text="Список комплектующих"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource BrandBlueBrush}"/>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,12,0,12">
            <TextBlock Text="Фильтр по типу:" VerticalAlignment="Center"/>
            <ComboBox Name="TypeFilterComboBox" Width="220" SelectionChanged="TypeFilterChanged"/>
            <Button Content="Обновить" Width="120" Click="RefreshClick"/>
        </StackPanel>

        <Border Grid.Row="2" Grid.Column="0" Classes="form-card" Padding="12" Margin="0,0,10,0">
            <StackPanel Spacing="8">
                <ListBox Name="ComponentsListBox" Height="420" SelectionChanged="ComponentSelectionChanged"/>
                <TextBlock Name="StatsTextBlock"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Classes="form-card" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Артикул"/>
                <TextBox Name="ArticleTextBox"/>
                <TextBlock Text="Наименование"/>
                <TextBox Name="NameTextBox"/>
                <TextBlock Text="Ед. измерения"/>
                <TextBox Name="UnitTextBox"/>
                <TextBlock Text="Количество"/>
                <TextBox Name="QuantityTextBox"/>
                <TextBlock Text="Цена закупки"/>
                <TextBox Name="PriceTextBox"/>
                <TextBlock Text="Тип комплектующего"/>
                <TextBox Name="TypeTextBox"/>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <Button Name="AddButton" Content="Добавить" Width="110" Click="AddClick"/>
                    <Button Name="UpdateButton" Content="Изменить" Width="110" Click="UpdateClick"/>
                    <Button Name="DeleteButton" Content="Удалить" Width="110" Click="DeleteClick"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
            <Button Content="Назад" Width="120" Click="BackClick"/>
            <TextBlock Name="MessageTextBlock" Foreground="{DynamicResource BrandRedBrush}" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
