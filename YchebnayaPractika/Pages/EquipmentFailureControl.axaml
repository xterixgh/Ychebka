<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
             x:Class="YchebnayaPractika.Pages.EquipmentFailureControl">
    <Grid Margin="20" ColumnDefinitions="2*,1*">
        <Border Grid.Column="0" Classes="form-card" Padding="12" Margin="0,0,10,0">
            <StackPanel Spacing="8">
                <TextBlock Text="Сбои оборудования" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrandBlueBrush}"/>
                <ListBox Name="FailuresListBox" Height="420" SelectionChanged="FailureSelectionChanged"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Classes="form-card" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Оборудование"/>
                <ComboBox Name="EquipmentComboBox"/>
                <TextBlock Text="Причина сбоя"/>
                <TextBox Name="ReasonTextBox"/>
                <TextBlock Text="Начало (дд.мм.гггг чч:мм)"/>
                <TextBox Name="StartTextBox"/>
                <TextBlock Text="Окончание (дд.мм.гггг чч:мм)"/>
                <TextBox Name="EndTextBox"/>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <Button Content="Зарегистрировать" Width="140" Click="RegisterClick"/>
                    <Button Content="Закрыть сбой" Width="120" Click="CloseFailureClick"/>
                </StackPanel>

                <Button Content="Назад" Width="120" Margin="0,8,0,0" Click="BackClick"/>
                <TextBlock Name="MessageTextBlock" Foreground="{DynamicResource BrandRedBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
