<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="YchebnayaPractika.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <!-- Palette from StyleGuide -->
        <Color x:Key="BrandRedColor">#BB0C07</Color>
        <Color x:Key="BrandSandColor">#F3CC8D</Color>
        <Color x:Key="BrandBlueColor">#4867AC</Color>
        <Color x:Key="ExtraLightYellowColor">#FEF9DE</Color>
        <Color x:Key="ExtraGrayColor">#F1F1F1</Color>
        <Color x:Key="TextBlackColor">#000000</Color>
        <Color x:Key="TextWhiteColor">#FFFFFF</Color>

        <SolidColorBrush x:Key="BrandRedBrush" Color="{StaticResource BrandRedColor}"/>
        <SolidColorBrush x:Key="BrandSandBrush" Color="{StaticResource BrandSandColor}"/>
        <SolidColorBrush x:Key="BrandBlueBrush" Color="{StaticResource BrandBlueColor}"/>
        <SolidColorBrush x:Key="ExtraLightYellowBrush" Color="{StaticResource ExtraLightYellowColor}"/>
        <SolidColorBrush x:Key="ExtraGrayBrush" Color="{StaticResource ExtraGrayColor}"/>
        <SolidColorBrush x:Key="TextBlackBrush" Color="{StaticResource TextBlackColor}"/>
        <SolidColorBrush x:Key="TextWhiteBrush" Color="{StaticResource TextWhiteColor}"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        
        <Style Selector="Window">
            <Setter Property="Background" Value="{StaticResource ExtraGrayBrush}"/>
            <Setter Property="FontFamily" Value="Century Gothic, Segoe UI, Arial"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlackBrush}"/>
        </Style>

        <Style Selector="UserControl">
            <Setter Property="FontFamily" Value="Century Gothic, Segoe UI, Arial"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlackBrush}"/>
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlackBrush}"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhiteBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{StaticResource BrandRedBrush}"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource TextWhiteBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlackBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="SelectionBrush" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="SelectionForegroundBrush" Value="{StaticResource TextWhiteBrush}"/>
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="{StaticResource TextWhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandSandBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlackBrush}"/>
        </Style>

        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhiteBrush}"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{StaticResource TextWhiteBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlackBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="ComboBox /template/ Popup Border">
            <Setter Property="Background" Value="{StaticResource TextWhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandSandBrush}"/>
        </Style>

        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource TextWhiteBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlackBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhiteBrush}"/>
        </Style>

        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhiteBrush}"/>
        </Style>

        <Style Selector="Border.form-card">
            <Setter Property="Background" Value="{StaticResource ExtraLightYellowBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandSandBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="Border.tool-icon">
            <Setter Property="Background" Value="{StaticResource TextWhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Border.tool-icon.selected">
            <Setter Property="BorderBrush" Value="{StaticResource BrandRedBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Application.Styles>
</Application>